{
  "manifest_version": 3,
  "name": "MarkUp by Myfrendo",
  "version": "2.0.0",
  "description": "Annotate any website live — arrows, pins, blur, text notes — then save as PNG. Design QA and developer handoff.",
  "permissions": ["activeTab", "scripting"],
  "homepage_url": "https://github.com/bykadzu/MarkUp",
  "offline_enabled": true,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/html2canvas.min.js", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "15.4"
    }
  }
}
